Процедура ДобавитьИнструменты(Инструменты) Экспорт

	ДобавитьИнструментВыполнениеКода(Инструменты);

КонецПроцедуры

Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт

	Если ИмяИнструмента = "execute_code" Тогда
		Возврат ВыполнитьКод(Аргументы);
	Иначе
		ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	КонецЕсли;

КонецФункции

#Область ИнструментВыполнениеКода

Процедура ДобавитьИнструментВыполнениеКода(Инструменты)

	МассивПараметров = Новый Массив;

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"code",
		"string",
		"Текст кода на встроенном языке 1С для выполнения",
		,
		Истина
	));

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"execute_code",
		"Выполнение произвольного кода на встроенном языке 1С:Предприятие",
		СхемаПараметров
	);

КонецПроцедуры

Функция ВыполнитьКод(Аргументы)

	Код = Аргументы.code;

	Попытка
		Выполнить(Код);
		Возврат mcp_Содержимое.ТекстовоеСодержимое("Код выполнен успешно");
	Исключение
		ВызватьИсключение ОписаниеОшибки();
	КонецПопытки;

КонецФункции

#КонецОбласти
