Процедура ДобавитьИнструменты(Инструменты) Экспорт

	ДобавитьИнструментЗапросДанных(Инструменты);

КонецПроцедуры

Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт

	Если ИмяИнструмента = "query_data" Тогда
		Возврат ВыполнитьЗапросДанных(Аргументы);
	Иначе
		ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	КонецЕсли;

КонецФункции

#Область ИнструментЗапросДанных

Процедура ДобавитьИнструментЗапросДанных(Инструменты)

	МассивПараметров = Новый Массив;

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"query",
		"string",
		"Текст запроса на языке запросов 1С:Предприятие",
		,
		Истина
	));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"limit",
		"number",
		"Максимальное количество строк в результате",
		100
	));

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"query_data",
		"Выполнение запроса на языке запросов 1С:Предприятие и получение результата в виде JSON",
		СхемаПараметров
	);

КонецПроцедуры

Функция ВыполнитьЗапросДанных(Аргументы)

	ТекстЗапроса = Аргументы.query;
	Лимит        = ?(Аргументы.Свойство("limit"), Аргументы.limit, 100);

	Запрос = Новый Запрос(ТекстЗапроса);

	Попытка
		РезультатЗапроса = Запрос.Выполнить();
	Исключение
		Возврат "Ошибка выполнения запроса: " + ОписаниеОшибки();
	КонецПопытки;

	КолонкиМассив = Новый Массив;
	Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
		КолонкиМассив.Добавить(Колонка.Имя);
	КонецЦикла;

	СтрокиМассив = Новый Массив;
	Счетчик      = 0;
	Выборка      = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		СтрокаСтруктура = Новый Структура;
		Для Каждого ИмяКолонки Из КолонкиМассив Цикл
			СтрокаСтруктура.Вставить(ИмяКолонки, Строка(Выборка[ИмяКолонки]));
		КонецЦикла;
		СтрокиМассив.Добавить(СтрокаСтруктура);

		Счетчик = Счетчик + 1;
		Если Счетчик >= Лимит Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("columns",  КолонкиМассив);
	Результат.Вставить("rows",     СтрокиМассив);
	Результат.Вставить("rowCount", Счетчик);

	Возврат mcp_Содержимое.ТекстовоеСодержимое(mcp_ОбщегоНазначения.СтруктураВJSON(Результат));

КонецФункции

#КонецОбласти
